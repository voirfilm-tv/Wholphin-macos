{
  "name": "wholphin-web",
  "version": "0.3.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc -p tsconfig.json && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src vite.config.js eslint.config.js",
    "test": "npm run test:compile && node --test tests/*.test.mjs",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:all": "npm run check && npm run test:e2e",
    "check": "npm run typecheck && npm run lint && npm test && npm run build",
    "test:compile": "rm -rf .test-dist && tsc -p tsconfig.test.json"
  },
  "dependencies": {
    "hls.js": "1.6.16"
  },
  "devDependencies": {
    "@eslint/js": "9.39.5",
    "@playwright/test": "1.61.1",
    "eslint": "9.39.5",
    "typescript": "5.9.2",
    "typescript-eslint": "8.64.0",
    "vite": "8.1.0"
  }
}
